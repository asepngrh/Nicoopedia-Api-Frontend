---
---

<!-- ─────────────────────────────────────────────────
     HISTORY TOGGLE BUTTON (floating, right edge)
───────────────────────────────────────────────────── -->
<button class="history-toggle-btn" id="history-toggle-btn" title="Request History" aria-label="Toggle request history">
  <!-- Clock icon -->
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"></circle>
    <polyline points="12 6 12 12 16 14"></polyline>
  </svg>
  <span class="history-toggle-label">History</span>
  <span class="history-count-badge" id="history-count-badge" style="display: none;">0</span>
</button>

<!-- ─────────────────────────────────────────────────
     HISTORY DRAWER PANEL
───────────────────────────────────────────────────── -->
<aside class="history-drawer" id="history-drawer" aria-label="Request history">

  <!-- Drawer header -->
  <div class="hd-header">
    <div class="hd-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <span>Request History</span>
    </div>
    <div class="hd-actions">
      <button class="hd-clear-btn" id="clear-history-btn" title="Clear all history">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"></polyline>
          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
        </svg>
        Clear
      </button>
      <button class="hd-close-btn btn-icon" id="history-close-btn" title="Close history">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Drawer body: list or empty state -->
  <div class="hd-body" id="history-body">

    <!-- Empty state -->
    <div id="history-empty" class="hd-empty">
      <div class="hd-empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
      </div>
      <p class="hd-empty-title">No requests yet</p>
      <p class="hd-empty-sub">Fetch an endpoint to start building your history</p>
    </div>

    <!-- History list (populated by JS) -->
    <div id="history-list" style="display: none;"></div>

  </div>

</aside>

<!-- Backdrop for mobile -->
<div class="history-backdrop" id="history-backdrop"></div>

<style>
  /* ── Toggle button ─────────────────────── */
  .history-toggle-btn {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.875rem 0.6rem;
    background: var(--bg-card-solid);
    border: 1px solid var(--border-color);
    border-right: none;
    border-radius: var(--radius-md) 0 0 var(--radius-md);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition-smooth);
    box-shadow: -4px 0 16px rgba(0,0,0,0.2);
  }

  .history-toggle-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .history-toggle-btn:hover {
    background: rgba(14,165,233,0.08);
    color: var(--accent-primary);
    border-color: rgba(14,165,233,0.25);
  }

  .history-toggle-btn.is-open {
    right: 340px;
    color: var(--accent-primary);
    border-color: rgba(14,165,233,0.25);
    background: rgba(14,165,233,0.06);
  }

  .history-toggle-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    writing-mode: vertical-rl;
  }

  .history-count-badge {
    background: var(--gradient-primary);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 800;
    min-width: 18px;
    height: 18px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    box-shadow: 0 2px 8px rgba(14,165,233,0.4);
  }

  /* ── Drawer ────────────────────────────── */
  .history-drawer {
    position: fixed;
    top: var(--header-height);
    right: 0;
    bottom: 0;
    width: 340px;
    z-index: 150;
    background: var(--bg-card-solid);
    border-left: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform var(--transition-smooth);
    box-shadow: -8px 0 32px rgba(0,0,0,0.3);
    will-change: transform;
  }

  .history-drawer.is-open {
    transform: translateX(0);
  }

  /* ── Drawer header ──────────────────────── */
  .hd-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-card-solid);
    flex-shrink: 0;
  }

  .hd-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hd-title svg {
    width: 15px;
    height: 15px;
    color: var(--accent-primary);
    flex-shrink: 0;
  }

  .hd-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hd-clear-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.65rem;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: var(--font-main);
  }

  .hd-clear-btn svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .hd-clear-btn:hover {
    color: var(--danger-color);
    background: rgba(239,68,68,0.07);
    border-color: rgba(239,68,68,0.15);
  }

  .hd-close-btn svg {
    width: 14px;
    height: 14px;
  }

  /* ── Drawer body ────────────────────────── */
  .hd-body {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Empty state ────────────────────────── */
  .hd-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex: 1;
    min-height: 260px;
    text-align: center;
    padding: 2rem 1.5rem;
    animation: fadeInUp 0.35s ease-out forwards;
  }

  .hd-empty-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(14,165,233,0.06);
    border: 1px solid rgba(14,165,233,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hd-empty-icon svg {
    width: 24px;
    height: 24px;
    color: var(--accent-primary);
    opacity: 0.4;
  }

  .hd-empty-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-secondary);
  }

  .hd-empty-sub {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.55;
    max-width: 220px;
  }

  /* ── Group header ───────────────────────── */
  .history-group-title {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    padding: 0.9rem 0.5rem 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .history-group-title::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border-color);
  }

  /* ── History card item ──────────────────── */
  .history-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
    margin-bottom: 4px;
    background: rgba(255,255,255,0.02);
    animation: slideIn 0.25s ease-out forwards;
    overflow: hidden;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .history-card:hover {
    background: rgba(14,165,233,0.05);
    border-color: rgba(14,165,233,0.15);
    transform: translateX(-2px);
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .history-card.is-active {
    background: rgba(14,165,233,0.08);
    border-color: rgba(14,165,233,0.25);
  }

  /* left accent stripe */
  .history-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 2px;
    border-radius: 2px;
    background: var(--border-color);
    transition: background var(--transition-fast), top var(--transition-fast), bottom var(--transition-fast);
  }

  .history-card:hover::before {
    top: 10%;
    bottom: 10%;
    background: var(--accent-primary);
  }

  .history-card.is-active::before {
    top: 5%;
    bottom: 5%;
    background: var(--accent-primary);
  }

  /* ── Card top row ───────────────────────── */
  .hc-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .hc-method {
    font-size: 0.6rem;
    font-weight: 800;
    color: var(--success-color);
    background: rgba(16,185,129,0.1);
    border: 1px solid rgba(16,185,129,0.2);
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .hc-endpoint {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-primary);
    font-family: var(--font-mono);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }

  /* ── Card bottom row ────────────────────── */
  .hc-bottom {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .hc-source {
    font-size: 0.72rem;
    color: var(--accent-primary);
    font-family: var(--font-mono);
    font-weight: 500;
    opacity: 0.85;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .hc-spacer { flex: 1; }

  .hc-time {
    font-size: 0.68rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-family: var(--font-mono);
  }

  .hc-ts {
    font-size: 0.65rem;
    color: var(--text-muted);
    opacity: 0.6;
    white-space: nowrap;
  }

  /* ── Hover action row ───────────────────── */
  .hc-hover-actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
    pointer-events: none;
    margin-top: 0.35rem;
    padding-top: 0.35rem;
    border-top: 1px solid rgba(51,65,85,0.15);
  }

  .history-card:hover .hc-hover-actions {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  /* ── Shared action button base ──────────── */
  .hc-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.18s ease;
    font-family: var(--font-main);
    letter-spacing: 0.02em;
    white-space: nowrap;
    position: relative;
    overflow: hidden;
  }

  .hc-action-btn svg {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
  }

  .hc-action-btn:disabled {
    opacity: 0.7;
    cursor: wait;
  }

  /* ── Replay button — PRIMARY (green accent) ── */
  .hc-replay-btn {
    background: rgba(16,185,129,0.12);
    color: #34d399;
    border-color: rgba(16,185,129,0.25);
  }

  .hc-replay-btn:hover:not(:disabled) {
    background: rgba(16,185,129,0.22);
    border-color: rgba(16,185,129,0.4);
    color: #6ee7b7;
    transform: translateY(-1px);
    box-shadow: 0 2px 10px rgba(16,185,129,0.2);
  }

  .hc-replay-btn:active:not(:disabled) {
    transform: translateY(0);
    box-shadow: none;
  }

  /* ── Copy button — SECONDARY (ghost/outline) ── */
  .hc-copy-btn {
    background: rgba(255,255,255,0.04);
    color: var(--text-muted);
    border-color: var(--border-color);
  }

  .hc-copy-btn:hover:not(:disabled) {
    background: rgba(14,165,233,0.08);
    color: var(--accent-primary);
    border-color: rgba(14,165,233,0.25);
    transform: translateY(-1px);
  }

  .hc-copy-btn:active:not(:disabled) {
    transform: translateY(0);
  }

  /* ── Copied feedback state ─────────────── */
  .hc-copied {
    background: rgba(16,185,129,0.12) !important;
    color: #34d399 !important;
    border-color: rgba(16,185,129,0.3) !important;
  }

  /* ── Inline spinner for replay running state ── */
  .hc-spinner {
    display: inline-block;
    width: 10px;
    height: 10px;
    border: 2px solid rgba(16,185,129,0.2);
    border-top-color: #34d399;
    border-radius: 50%;
    animation: hcSpin 0.6s linear infinite;
    flex-shrink: 0;
  }

  @keyframes hcSpin {
    to { transform: rotate(360deg); }
  }

  /* ── Backdrop (mobile) ──────────────────── */
  .history-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 140;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity var(--transition-smooth);
  }

  .history-backdrop.is-visible {
    display: block;
    opacity: 1;
  }

  /* ── Responsive ─────────────────────────── */
  @media (max-width: 768px) {
    .history-drawer {
      top: 0;
      width: 100%;
      max-width: 360px;
      box-shadow: -4px 0 32px rgba(0,0,0,0.5);
    }

    .history-toggle-btn.is-open {
      right: 360px;
    }
  }

  @media (max-width: 480px) {
    .history-toggle-btn {
      top: auto;
      bottom: 1.25rem;
      right: 0;
      transform: none;
      flex-direction: row;
      border-radius: var(--radius-md) 0 0 var(--radius-md);
      padding: 0.65rem 0.875rem;
    }

    .history-toggle-label {
      writing-mode: horizontal-tb;
    }

    .history-toggle-btn.is-open {
      right: 100%;
    }
  }
</style>
