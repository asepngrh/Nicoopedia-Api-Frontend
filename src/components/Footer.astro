---
// Footer.astro
---
<footer class="app-footer">
  <div class="footer-left">
    <span class="footer-brand">Nicoopedia<b>BASE</b></span>
    <span class="footer-sep">|</span>
    <span class="footer-desc">API Explorer Workspace</span>
  </div>
  
  <div class="footer-center">
    <!-- Optional center info or empty -->
  </div>

  <div class="footer-right">
    <span class="footer-creator">Designed by <b class="creator-name">Nicoopedia</b></span>
    <span class="footer-sep">|</span>
    <a href="#" class="footer-link">GitHub</a>
    <span class="footer-sep">|</span>
    <span class="footer-copyright">&copy; {new Date().getFullYear()}</span>
  </div>
</footer>

<style is:global>
  .app-footer {
    height: 38px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    background: var(--bg-header);
    border-top: 1px solid var(--border-color);
    font-size: 0.75rem;
    color: var(--text-muted);
    z-index: 50;
    backdrop-filter: blur(20px) saturate(180%);
  }

  .footer-left, .footer-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-brand {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .footer-brand b {
    color: var(--primary);
    font-weight: 700;
  }

  .footer-sep {
    color: var(--border-color);
    opacity: 0.5;
  }

  .footer-desc {
    display: none;
  }

  @media (min-width: 768px) {
    .footer-desc {
      display: inline-block;
    }
  }

  .creator-name {
    color: var(--text-primary);
    font-weight: 600;
    transition: color 0.2s;
  }
  
  .creator-name:hover {
    color: var(--accent-primary);
  }

  .footer-link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--text-primary);
  }
</style>
